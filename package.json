{
  "name": "@cr4yfish/react-web-mcp",
  "version": "0.3.5",
  "description": "React hooks and components for the WebMCP standard \u2014 expose your web app's functionality as tools for in-browser AI agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cr4yfish/react-web-mcp.git"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "model-context-protocol",
    "react",
    "nextjs",
    "ai",
    "agents",
    "browser-agent",
    "modelcontext"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    }
  },
  "files": [
    "dist",
    "doc",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "tsc": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
